{
  "name": "nbcapi",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev:server": "ts-node-dev --respawn --transpile-only --poll ./src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only --poll ./src/worker.ts",
    "dev:events": "ts-node-dev --respawn --transpile-only --poll ./src/events.ts",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:prod": "docker-compose up --build",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:events\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "date-fns": "^3.4.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "google-auth-library": "^10.6.1",
    "handlebars": "^4.7.8",
    "html-to-text": "^9.0.5",
    "jsonwebtoken": "^9.0.2",
    "mjml": "^4.18.0",
    "mongoose": "^8.2.2",
    "mongoose-sequence": "^6.0.1",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.9.12",
    "p-limit": "^7.3.0",
    "streamifier": "^0.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/html-to-text": "^9.0.4",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mjml": "^4.7.4",
    "@types/mongoose-sequence": "^3.0.11",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^6.4.14",
    "@types/streamifier": "^0.1.2",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0"
  }
}
